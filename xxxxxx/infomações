function confirmarDeletarMaster(masterId){
  const db=load();
  const c=db.clientes.find(x=>x.id===masterId);
  const negs=db.empresas.filter(e=>e.dono_id===masterId).length;
  confirmarAcao(
    '⚠️ Deletar conta Master',
    `Isso irá remover permanentemente a conta de "${c?.nome||'usuário'}", seu ID Pessoal e desvincular ${negs} negócio(s). Os perfis de empresa continuam no sistema como Comunidade. Esta ação não pode ser desfeita.`,
    ()=>{
      const db2=load();
      db2.clientes=db2.clientes.filter(x=>x.id!==masterId);
      db2.empresas.forEach(e=>{if(e.dono_id===masterId){e.dono_id='';e.status_perfil='comunidade';}});
      if(db2.sugestoes) db2.sugestoes=db2.sugestoes.filter(s=>s.autor_id!==masterId);
      save(db2);renderClientes();renderDashboard();
      toast('Conta e todos os IDs vinculados foram removidos.');
    }
  );
}

