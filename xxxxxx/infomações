      document.getElementById('sug-criar-empresa-label').textContent='Sim, ativar perfil e vincular ao dono';
    } else {
      wrap.className='rounded-xl p-4 border bg-teal-50 border-teal-200';
      document.getElementById('sug-aprovado-msg').className='text-[13px] font-semibold mb-2 text-teal-700';
      document.getElementById('sug-aprovado-msg').textContent='🤝 Ao aprovar, a empresa será adicionada como perfil da Comunidade (sem dono).';
      document.getElementById('sug-criar-label').className='flex items-center gap-2 cursor-pointer text-[13px] text-teal-700';
      document.getElementById('sug-criar-empresa-label').textContent='Sim, adicionar à comunidade';
    }
  }
}

function salvarSugestao(){
  const nome=document.getElementById('sug-nome').value.trim();
  if(!nome){toast('Nome da empresa é obrigatório.','err');return;}
  const db=load();
  if(!db.sugestoes)db.sugestoes=[];
  const editId=document.getElementById('sug-id').value;
  const status=document.getElementById('sug-status').value;
  const is_dono=document.getElementById('sug-is-dono').checked;
  // preserva campos originais do cliente ao editar
  const sugOriginal = editId ? (db.sugestoes.find(s=>s.id===editId)||{}) : {};

  const getVal=(id,fallback='')=>{const el=document.getElementById(id);return el?el.value.trim():fallback;};

  const rua=getVal('sug-rua');
  const num=getVal('sug-num');
  const bairro=getVal('sug-bairro');
  const cidade=getVal('sug-cidade');
  const uf=getVal('sug-uf')||sugOriginal.uf||'';

  // Recalcula endereco compacto se campos detalhados preenchidos
  let enderecoCompacto = sugOriginal.endereco||'';
  if(rua||cidade){
    let parts=[];
    if(rua)parts.push(rua+(num?', '+num:''));
    if(bairro)parts.push(bairro);
    if(cidade)parts.push(cidade+(uf?' - '+uf:''));
    enderecoCompacto=parts.join(' | ');
  } else {
    // endereço legado removido
  }

  const sug={
    id:editId||gid(),
    autor_id: sugOriginal.autor_id || '',
    nome,
    segmento:getVal('sug-segmento'),
    tel:getVal('sug-tel'),
    email:getVal('sug-email'),
    ig:getVal('sug-ig'),
    site:getVal('sug-site'),
    cardapio:getVal('sug-cardapio'),
    endereco:enderecoCompacto,
    rua, num, comp:sugOriginal.comp||'', bairro, cep:getVal('sug-cep'), cidade, uf,
    horarios:sugOriginal.horarios||null,
    hh_desc:sugOriginal.hh_desc||'',
    oferta_tipo:getVal('sug-oferta-tipo','Produto/Brinde Grátis')||sugOriginal.oferta_tipo||'',
    oferta_val:getVal('sug-oferta-val','No dia do aniversário')||sugOriginal.oferta_val||'',
    oferta_desc:getVal('sug-oferta-desc'),
    oferta_regras:getVal('sug-oferta-regras'),
    obs:getVal('sug-obs'),
    status,
    is_dono,
    criado_em:sugOriginal.criado_em||new Date().toISOString(),
    atualizado_em:new Date().toISOString(),
  };
  if(editId){const i=db.sugestoes.findIndex(s=>s.id===editId);if(i!==-1)db.sugestoes[i]=sug;}
  else db.sugestoes.unshift(sug);

  if(status==='aprovado'&&document.getElementById('sug-criar-empresa').checked){
    if(sug.is_dono){
      // ID_EMPRESA: converte a própria sugestão em empresa vinculada ao dono
      // Não gera novo ID — usa o id da sugestão para rastreabilidade, mas cria entrada em empresas
      // Verifica se já existe empresa originada desta sugestão (evita duplicar em re-aprovações)
      const jaExiste = db.empresas.some(e=>e.origem_sug_id===sug.id);
      if(!jaExiste){
        const novaEmp={
          id: gid(),
          origem_sug_id: sug.id,           // rastreabilidade
          nome: sug.nome,
          dono_id: sug.autor_id,            // sempre vincula ao autor
          status_perfil: 'verificado',
          segmento: sug.segmento||'',
          tel: sug.tel||'',
          email: sug.email||'',
          ig: sug.ig||'',
          site: sug.site||'',
          cardapio: sug.cardapio||'',
          rua: sug.rua||'', num: sug.num||'', comp: sug.comp||'',
          bairro: sug.bairro||'', cep: sug.cep||'',
          cidade: sug.cidade||'', uf: sug.uf||'',
          horarios: sug.horarios||null,
          hh_desc: sug.hh_desc||'',
          oferta_tipo: sug.oferta_tipo||'Produto/Brinde Grátis',
          oferta_val: sug.oferta_val||'No dia do aniversário',
          oferta_desc: sug.oferta_desc||'',
          oferta_regras: sug.oferta_regras||'',
          criado_em: sug.criado_em||new Date().toISOString(),
          aprovado_em: new Date().toISOString(),
          origem: 'solicitacao_dono'
        };
        db.empresas.unshift(novaEmp);
        toast('Solicitação aprovada! Empresa vinculada ao ID Master do solicitante. 🛡️');
      } else {
        toast('Solicitação aprovada. Empresa já estava ativa no sistema.');
      }
    } else {
      // ID_INDICAÇÃO: cria empresa comunidade SEM dono
      const jaExiste = db.empresas.some(e=>e.origem_sug_id===sug.id);
      if(!jaExiste){
        const novaEmp={
          id: gid(),
          origem_sug_id: sug.id,
          nome: sug.nome,
          dono_id: '',                       // sem dono — empresa da comunidade
          status_perfil: 'comunidade',
          segmento: sug.segmento||'',
          tel: sug.tel||'',
          email: sug.email||'',
          ig: sug.ig||'',
          site: sug.site||'',
          cardapio: sug.cardapio||'',
          rua: sug.rua||sug.endereco||'', num: sug.num||'', comp: sug.comp||'',
          bairro: sug.bairro||'', cep: sug.cep||'',
          cidade: sug.cidade||'', uf: sug.uf||'',
          horarios: sug.horarios||null,
          hh_desc: sug.hh_desc||'',
          oferta_tipo: sug.oferta_tipo||'Produto/Brinde Grátis',
          oferta_val: sug.oferta_val||'No dia do aniversário',
          oferta_desc: sug.oferta_desc||'',
          oferta_regras: sug.oferta_regras||'',
          criado_em: new Date().toISOString(),
          origem: 'indicacao_comunidade'
        };
        db.empresas.unshift(novaEmp);
        toast('Indicação aprovada! Empresa adicionada à comunidade. 🤝');
      } else {
        toast('Indicação aprovada. Empresa já estava no sistema.');
      }
    }
  } else {
    toast(editId?'Sugestão atualizada!':'Sugestão registrada!');
  }
  save(db);closeModal('modal-sug');
  // Atualiza o painel correto dependendo do tipo
  const isSugDono = document.getElementById('sug-is-dono').checked;
  if(isSugDono){ if(typeof renderSolicitacoes==='function') renderSolicitacoes(); }
  else renderSugestoes();
  updateSugestoesBadge();
}

function filterSugestoes(status,btn){
  sugestaoFiltro=status;
  document.querySelectorAll('.sug-filter-btn').forEach(b=>b.classList.remove('ring-2','ring-offset-1','ring-primary'));
  if(btn)btn.classList.add('ring-2','ring-offset-1','ring-primary');
  renderSugestoes();
}

function renderSugestoes(){
  const db=load();
  // Só indicações de clientes (não donos)
  let list=(db.sugestoes||[]).filter(s=>!s.is_dono);
  // Filtrar por status
  if(sugestaoFiltro)list=list.filter(s=>s.status===sugestaoFiltro);
  const container=document.getElementById('sugestoes-list'),empty=document.getElementById('sugestoes-empty');
  if(!list.length){container.innerHTML='';empty.classList.remove('hidden');return;}
  empty.classList.add('hidden');
  const statusBadge=s=>({
    pendente:'<span class="inline-flex px-2 py-0.5 rounded-full text-[10.5px] font-semibold bg-yellow-50 text-yellow-700 border border-yellow-200">⏳ Pendente</span>',
    aprovado:'<span class="inline-flex px-2 py-0.5 rounded-full text-[10.5px] font-semibold bg-green-50 text-green-700 border border-green-200">✓ Aprovado</span>',
    recusado:'<span class="inline-flex px-2 py-0.5 rounded-full text-[10.5px] font-semibold bg-red-50 text-red-600 border border-red-200">✕ Recusado</span>',
  })[s]||'';
  
  container.innerHTML=list.map(s=>{
    const autorCliente=(db.clientes||[]).find(c=>c.id===s.autor_id);
    const empresasDoMaster = s.is_dono && autorCliente
      ? (db.empresas||[]).filter(e=>e.dono_id===autorCliente.id)
      : [];
    const badgeDono = s.is_dono 
      ? '<span class="inline-flex px-2 py-0.5 rounded-full text-[10px] font-bold bg-purple-50 text-purple-700 border border-purple-200">👑 ID_EMPRESA</span>' 
      : '<span class="inline-flex px-2 py-0.5 rounded-full text-[10px] font-bold bg-gray-100 text-gray-600 border border-gray-200">💡 ID_INDICAÇÃO</span>';
    const badgeAutor = autorCliente
      ? `<span class="inline-flex px-2 py-0.5 rounded-full text-[10px] font-semibold bg-green-50 text-green-700 border border-green-200">📱 ${autorCliente.nome}</span>`
      : '';
    const addrLine = s.rua ? [s.rua+(s.num?', '+s.num:''), s.bairro, s.cidade+(s.uf?' - '+s.uf:'')].filter(Boolean).join(' | ') : s.endereco;
    const ofertaLine = s.oferta_desc ? `<p class="text-[12.5px] text-primary font-medium mb-1">🎁 ${s.oferta_desc}</p>` : '';

    // Mini-painel de empresas do Master (só para aba "Avaliar Permissões")
    const empContextHtml = s.is_dono && autorCliente ? `
      <div class="mt-3 pt-3 border-t border-purple-100">
        <p class="text-[10.5px] font-bold text-purple-600 uppercase tracking-wider mb-1.5">Empresas vinculadas ao Master de ${autorCliente.nome.split(' ')[0]}</p>
        ${empresasDoMaster.length
          ? empresasDoMaster.map(e=>`<span class="inline-flex items-center gap-1 mr-2 mb-1 px-2 py-0.5 rounded-md text-[11px] font-medium bg-purple-50 text-purple-700 border border-purple-200">${e.status_perfil==='verificado'?'🛡️':'🤝'} ${e.nome}</span>`).join('')
          : '<span class="text-[11.5px] text-ink-muted italic">Nenhuma empresa vinculada ainda — esta seria a primeira.</span>'
        }
      </div>` : '';

    return `
    <div class="bg-white rounded-2xl border ${s.is_dono?'border-purple-200':'border-edge'} shadow-sm p-5 flex items-start gap-4">
      <div class="w-10 h-10 rounded-xl ${s.is_dono?'bg-purple-100 border-purple-200':'bg-surface-3 border-edge'} border flex items-center justify-center text-xl shrink-0">${s.is_dono?'👑':'🏢'}</div>
      <div class="flex-1 min-w-0">
        <div class="flex items-center gap-2 mb-1 flex-wrap">
          <span class="font-bold text-[14px]">${s.nome}</span>
          ${badgeDono}
          ${badgeAutor}
          ${statusBadge(s.status)}
          ${s.segmento?`<span class="inline-flex px-2 py-0.5 rounded-full text-[10.5px] font-semibold bg-surface-3 text-ink-muted border border-edge">${s.segmento}</span>`:''}
        </div>
        ${addrLine?`<p class="text-[12.5px] text-ink-muted mb-1">📍 ${addrLine}</p>`:''}
        ${ofertaLine}
        ${s.tel?`<p class="text-[12.5px] text-ink-muted mono mb-1">📞 ${s.tel}</p>`:''}
        ${s.obs?`<p class="text-[12.5px] text-ink-muted italic">"${s.obs}"</p>`:''}
        ${empContextHtml}
        <p class="text-[11px] text-ink-light mt-2">${fmtDatetime(s.criado_em)}</p>
      </div>
      <div class="flex gap-2 shrink-0">
        <button onclick="openSugestaoModal('${s.id}')" class="text-[12px] font-semibold ${s.is_dono?'bg-purple-50 text-purple-700 border-purple-200 hover:bg-purple-100':'border-edge hover:bg-surface-3'} border rounded-lg px-3 py-1.5 transition-colors">${s.is_dono?'🔑 Analisar':'✏️ Analisar'}</button>
        <button onclick="confirmar('sugestao','${s.id}')" class="text-[12px] font-semibold bg-red-50 text-red-600 border border-red-200 rounded-lg px-2.5 py-1.5 hover:bg-red-100 transition-colors">🗑</button>
      </div>
    </div>`
  }).join('');
}

function excluirSugestao(id){
  const db=load();
  const sug=(db.sugestoes||[]).find(s=>s.id===id);
  const wasDono=sug&&sug.is_dono;
  db.sugestoes=(db.sugestoes||[]).filter(s=>s.id!==id);
  save(db);
  if(wasDono) renderSolicitacoes(); else renderSugestoes();
  updateSugestoesBadge();toast('Removido.');
}

function updateSugestoesBadge(){
  const db=load();
  // Badge "Indicações" no nav: indicações de clientes pendentes (is_dono=false)
  const pendingInd=(db.sugestoes||[]).filter(s=>s.status==='pendente'&&!s.is_dono).length;
  const badgeInd=document.getElementById('badge-sugestoes');
  if(pendingInd>0){badgeInd.classList.remove('hidden');badgeInd.textContent=pendingInd;}
  else badgeInd.classList.add('hidden');

  // Badge "Empresas" no nav: solicitações de donos pendentes (is_dono=true)
  const pendingSol=(db.sugestoes||[]).filter(s=>s.status==='pendente'&&s.is_dono).length;
  const badgeSol=document.getElementById('badge-solicitacoes');
  if(pendingSol>0){badgeSol.classList.remove('hidden');badgeSol.textContent=pendingSol;}
  else badgeSol.classList.add('hidden');

  // Badge na aba interna de Solicitações
  const badgeSolTab=document.getElementById('badge-sol-tab');
  if(badgeSolTab){
    if(pendingSol>0){badgeSolTab.classList.remove('hidden');badgeSolTab.textContent=pendingSol;}
    else badgeSolTab.classList.add('hidden');
  }
}

