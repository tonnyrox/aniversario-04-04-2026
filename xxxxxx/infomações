  document.getElementById('e-step-label').textContent = 'Etapa 1 de 5';
  
  for (let i = 1; i <= 5; i++) {
    const dot = document.getElementById('e-dot-' + i);
    if (dot) dot.style.background = i === 1 ? '#3b5bdb' : '#e2e8f0';
