    const bairroEl=document.getElementById('sug-bairro');if(bairroEl)bairroEl.value=sug.bairro||'';
    const cepEl=document.getElementById('sug-cep');if(cepEl)cepEl.value=sug.cep||'';
    const cidadeEl=document.getElementById('sug-cidade');if(cidadeEl)cidadeEl.value=sug.cidade||'';
    document.getElementById('sug-obs').value=sug.obs||'';
    document.getElementById('sug-status').value=sug.status||'pendente';
    document.getElementById('sug-is-dono').checked=sug.is_dono||false;
    // Oferta
    if(sug.oferta_tipo&&ofTipoEl)ofTipoEl.value=sug.oferta_tipo;
    if(sug.oferta_val&&ofValEl)ofValEl.value=sug.oferta_val;
    const odEl=document.getElementById('sug-oferta-desc');if(odEl)odEl.value=sug.oferta_desc||'';
    const orEl=document.getElementById('sug-oferta-regras');if(orEl)orEl.value=sug.oferta_regras||'';
    // Autor — painel rico de contexto
    if(sug.autor_id){
      const autor=(db.clientes||[]).find(c=>c.id===sug.autor_id);
      const autorWrap=document.getElementById('sug-autor-wrap');
      if(autor&&autorWrap){
        // Estilo do painel: roxo para dono, azul para indicação
        if(sug.is_dono){
          autorWrap.className='rounded-2xl border border-purple-200 overflow-hidden bg-purple-50/30';
          document.getElementById('sug-autor-header').className='px-4 py-3 flex items-center gap-3 bg-purple-50';
          document.getElementById('sug-autor-avatar').className='w-9 h-9 rounded-xl flex items-center justify-center text-base font-bold shrink-0 bg-purple-100 text-purple-700 border border-purple-300';
          document.getElementById('sug-autor-tipo-badge').className='text-[10px] font-bold px-2 py-0.5 rounded-full bg-purple-100 text-purple-700 border border-purple-200';
          document.getElementById('sug-autor-tipo-badge').textContent='👑 Solicita ID_EMPRESA';
        } else {
          autorWrap.className='rounded-2xl border border-primary-border overflow-hidden';
          document.getElementById('sug-autor-header').className='px-4 py-3 flex items-center gap-3 bg-primary-light';
          document.getElementById('sug-autor-avatar').className='w-9 h-9 rounded-xl flex items-center justify-center text-base font-bold shrink-0 bg-primary-light text-primary border border-primary-border';
          document.getElementById('sug-autor-tipo-badge').className='text-[10px] font-bold px-2 py-0.5 rounded-full bg-blue-50 text-blue-700 border border-blue-200';
          document.getElementById('sug-autor-tipo-badge').textContent='💡 Indicação (ID_INDICAÇÃO)';
        }
        autorWrap.classList.remove('hidden');
        document.getElementById('sug-autor-avatar').textContent=autor.nome.charAt(0).toUpperCase();
        document.getElementById('sug-autor-nome').textContent=autor.nome||'';
        document.getElementById('sug-autor-contato').textContent=[autor.tel,autor.email].filter(Boolean).join(' · ')||'Sem contato';
        document.getElementById('sug-autor-master-id').textContent=autor.id;

        // Empresas vinculadas ao Master
        const empresasDoMaster=(db.empresas||[]).filter(e=>e.dono_id===autor.id);
        const empWrap=document.getElementById('sug-autor-empresas-wrap');
        const empList=document.getElementById('sug-autor-empresas-list');
        if(sug.is_dono){
          empWrap.classList.remove('hidden');
          if(empresasDoMaster.length){
            empList.innerHTML=empresasDoMaster.map(e=>`
              <div class="flex items-center gap-2 bg-white border border-purple-100 rounded-lg px-3 py-1.5">
                <span class="text-[10px] font-bold text-purple-500 mono shrink-0">ID_NEGÓCIO</span>
                <span class="text-[10.5px] text-ink-muted mono shrink-0">${e.id}</span>
                <span class="font-semibold text-[12px] truncate">${e.nome}</span>
                ${e.status_perfil==='verificado'?'<span class="text-[10px] ml-auto shrink-0">🛡️ Verificado</span>':'<span class="text-[10px] text-ink-muted ml-auto shrink-0">🤝 Comunidade</span>'}
              </div>`).join('');
          } else {
            empList.innerHTML='<p class="text-[12px] text-ink-muted italic">Nenhuma empresa vinculada ainda — esta seria a primeira.</p>';
          }
        } else {
          empWrap.classList.add('hidden');
        }

        // Indicações da pessoa
        const indicacoesDoAutor=(db.sugestoes||[]).filter(s=>s.autor_id===autor.id&&!s.is_dono);
        const indWrap=document.getElementById('sug-autor-indicacoes-wrap');
        const indList=document.getElementById('sug-autor-indicacoes-list');
        if(indicacoesDoAutor.length){
          indWrap.classList.remove('hidden');
          const statusLabel={aprovado:'✓ Aprovada',pendente:'⏳ Pendente',recusado:'✕ Recusada'};
          indList.innerHTML=indicacoesDoAutor.slice(0,5).map(ind=>`
            <div class="flex items-center justify-between gap-2 text-[12px]">
              <span class="truncate font-medium">${ind.nome}</span>
              <span class="shrink-0 text-[10.5px] text-ink-muted">${statusLabel[ind.status]||ind.status}</span>
            </div>`).join('');
          if(indicacoesDoAutor.length>5) indList.innerHTML+=`<p class="text-[11px] text-ink-muted mt-1">+${indicacoesDoAutor.length-5} mais...</p>`;
        } else {
          indWrap.classList.add('hidden');
        }
      }
    }
    // Tipo do modal
    document.getElementById('sug-modal-title').textContent=sug.is_dono?'Avaliar Permissão de Negócio':'Analisar Indicação';
    const origemEl=document.getElementById('sug-modal-origem');
    if(origemEl){
      origemEl.textContent=sug.is_dono?'👑 Solicitação de dono — aguardando aprovação':'💡 Indicação de comunidade';
      origemEl.classList.remove('hidden');
    }
    toggleSugStatus();
  }
  // reset steps
  _sgCurrentStep=1;
  document.querySelectorAll('#modal-sug .n-step').forEach(s=>s.classList.remove('active'));
  document.getElementById('sg-step-1').classList.add('active');
  document.getElementById('sg-prev-btn').classList.add('hidden');
  document.getElementById('sg-next-btn').textContent='Próximo →';
  document.getElementById('sg-step-label').textContent='Etapa 1 de 4';
  for(let i=1;i<=4;i++) document.getElementById('sg-dot-'+i).style.background=i===1?'#2563eb':'#e2e8f0';
  openModal('modal-sug');
}

function toggleSugStatus(){
  const s=document.getElementById('sug-status').value;
  const isDono=document.getElementById('sug-is-dono').checked;
  const wrap=document.getElementById('sug-aprovado-action');
  wrap.classList.toggle('hidden',s!=='aprovado');
  if(s==='aprovado'){
    if(isDono){
      wrap.className='rounded-xl p-4 border bg-purple-50 border-purple-200';
      document.getElementById('sug-aprovado-msg').className='text-[13px] font-semibold mb-2 text-purple-700';
      document.getElementById('sug-aprovado-msg').textContent='🛡️ Ao aprovar, a empresa será ativada e vinculada ao ID Master do solicitante.';
