  empTab=tab;
  document.querySelectorAll('.emp-tab-btn').forEach(b=>{b.classList.remove('bg-white','text-ink','shadow-sm');b.classList.add('text-ink-muted');});
  const active=document.getElementById('emp-tab-'+tab);
  if(active){active.classList.add('bg-white','text-ink','shadow-sm');active.classList.remove('text-ink-muted');}
  document.getElementById('emp-panel-ativas').classList.toggle('hidden',tab!=='ativas');
  document.getElementById('emp-panel-solicitacoes').classList.toggle('hidden',tab!=='solicitacoes');
  if(tab==='ativas') renderEmpresas();
  else renderSolicitacoes();
}

function filterSolicitacoes(status,btn){
  solFiltro=status;
  document.querySelectorAll('.sol-filter-btn').forEach(b=>b.classList.remove('ring-2','ring-offset-1','ring-primary'));
  if(btn)btn.classList.add('ring-2','ring-offset-1','ring-primary');
  renderSolicitacoes();
}

function renderSolicitacoes(){
  const db=load();
  let list=(db.sugestoes||[]).filter(s=>s.is_dono);
  if(solFiltro)list=list.filter(s=>s.status===solFiltro);
  const container=document.getElementById('solicitacoes-list');
  const empty=document.getElementById('solicitacoes-empty');
  if(!list.length){container.innerHTML='';empty.classList.remove('hidden');return;}
  empty.classList.add('hidden');

