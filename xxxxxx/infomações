// ANIVCRM - SISTEMA CONSOLIDADO v2.0 - SCRIPTS COMPLETO
// ═══════════════════════════════════════════════════════════════════

// ── TAILWIND CONFIG ─────────────────────────────────────────────────
tailwind.config = {
