function hhResumo(e){
  if(!e||!e.horarios)return'';
  const nomes={'Segunda-feira':'Seg','Terça-feira':'Ter','Quarta-feira':'Qua','Quinta-feira':'Qui','Sexta-feira':'Sex','Sábado':'Sáb','Domingo':'Dom'};
  const diasHH=e.horarios.filter(h=>h.hh&&!h.fechado);
  if(!diasHH.length)return'';
  const rows=diasHH.map(h=>{
    const hhSlots=(h.hh_slots||[]).map(s=>s.ini&&s.fim?s.ini+'–'+s.fim:'').filter(Boolean);
    const funcSlots=(h.slots||[]).map(s=>s.ini&&s.fim?s.ini+'–'+s.fim:'').filter(Boolean);
    // Alerta visual se HH está fora do horário de funcionamento
    let alerta='';
    if(hhSlots.length&&funcSlots.length){
      const hhFim=hhSlots[hhSlots.length-1].split('–')[1]||'';
      const funcFim=funcSlots[funcSlots.length-1].split('–')[1]||'';
      if(hhFim>funcFim) alerta='<span class="text-[9.5px] text-red-500 font-bold ml-1" title="HH ultrapassa fechamento">⚠️</span>';
    }
    const notaHH=h.hh_nota?`<span class="text-[10px] text-yellow-600 italic ml-1">· ${h.hh_nota}</span>`:'';
    return`<div class="flex items-baseline gap-1 flex-wrap">
      <span class="text-[10.5px] font-bold text-yellow-700 bg-yellow-50 border border-yellow-200 rounded px-1.5 py-0.5">${nomes[h.dia]||h.dia.substring(0,3)}</span>
      ${hhSlots.length?`<span class="text-[10.5px] text-yellow-600 mono">${hhSlots.join(', ')}</span>`:''}
      ${funcSlots.length?`<span class="text-[9.5px] text-ink-muted">(func: ${funcSlots.join(', ')})</span>`:''}
      ${alerta}${notaHH}
    </div>`;
  }).join('');
  const desc=e.hh_desc?`<p class="text-[10.5px] text-ink-muted italic mt-1">📝 ${e.hh_desc}</p>`:'';
  return`<div class="mt-2 pt-2 border-t border-yellow-100/70 space-y-0.5">${rows}${desc}</div>`;
}

