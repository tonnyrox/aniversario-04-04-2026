// ── DATE/TIME HELPERS ──────────────────────────────────
function fmtDate(s){if(!s)return'—';const[y,m,d]=s.split('-');return`${d}/${m}/${y}`;}
function mmdd(d){return String(d.getMonth()+1).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0');}
function bdayMMDD(s){if(!s)return'';const p=s.split('-');return p[1]+'-'+p[2];}
function bdayThisWeek(s){if(!s)return false;const d=new Date(),t=new Date(d.getFullYear(),d.getMonth(),d.getDate()),b=new Date(d.getFullYear(),parseInt(s.split('-')[1])-1,parseInt(s.split('-')[2]));if(b<t)b.setFullYear(b.getFullYear()+1);const diff=(b-t)/(1000*60*60*24);return diff>=0&&diff<=7;}
function fmtDatetime(s){if(!s)return'—';try{const d=new Date(s);return d.toLocaleDateString('pt-BR',{day:'2-digit',month:'short',year:'numeric'})+' '+d.toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'});}catch{return'—';}}


