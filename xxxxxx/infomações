function aprovarSolicitacao(id){
  const db=load();
  const sug=(db.sugestoes||[]).find(s=>s.id===id);
  if(!sug)return;
  sug.status='aprovado';
  // Cria empresa vinculada ao dono se ainda não existe
  const jaExiste=db.empresas.some(e=>e.origem_sug_id===id);
  if(!jaExiste){
    db.empresas.unshift({
      id:gid(),origem_sug_id:id,nome:sug.nome,dono_id:sug.autor_id,status_perfil:'verificado',
      segmento:sug.segmento||'',tel:sug.tel||'',email:sug.email||'',ig:sug.ig||'',site:sug.site||'',
      cardapio:sug.cardapio||'',rua:sug.rua||'',num:sug.num||'',comp:sug.comp||'',
      bairro:sug.bairro||'',cep:sug.cep||'',cidade:sug.cidade||'',uf:sug.uf||'',
      horarios:sug.horarios||null,hh_desc:sug.hh_desc||'',
      oferta_tipo:sug.oferta_tipo||'Produto/Brinde Grátis',oferta_val:sug.oferta_val||'No dia do aniversário',
      oferta_desc:sug.oferta_desc||'',oferta_regras:sug.oferta_regras||'',
      criado_em:sug.criado_em||new Date().toISOString(),aprovado_em:new Date().toISOString(),origem:'solicitacao_dono'
    });
  }
  save(db);renderSolicitacoes();updateSugestoesBadge();
  toast('Solicitação aprovada! Empresa vinculada ao dono. 🛡️');
}

function recusarSolicitacao(id){
  const db=load();
