function renderRelatorios(){
  const db=load();
  const totalEmp=db.empresas.length;
  const totalCli=db.clientes.length;
  const enviadas=db.clientes.filter(c=>c.oferta_enviada).length;
  const pendentes=totalCli-enviadas;
  const pct=totalCli?Math.round((enviadas/totalCli)*100):0;
  const hhEmps=db.empresas.filter(e=>e.horarios&&e.horarios.some(h=>h.hh));
  const empCount=db.empresas.map(e=>({...e,count:db.clientes.filter(c=>c.emp_id===e.id).length})).sort((a,b)=>b.count-a.count).slice(0,6);
  const maxCount=empCount[0]?.count||1;
  const meses=['Jan','Fev','Mar','Abr','Mai','Jun','Jul','Ago','Set','Out','Nov','Dez'];
  const bDayPerMonth=meses.map((_,i)=>db.clientes.filter(c=>c.nasc&&parseInt(c.nasc.split('-')[1])-1===i).length);
  const maxBday=Math.max(...bDayPerMonth,1);

  const topEmpHTML=empCount.length?empCount.map(e=>`
    <div class="flex items-center gap-3 mb-3">
      <span class="text-[12.5px] font-medium w-36 truncate shrink-0">${e.nome}</span>
      <div class="flex-1 bg-surface-3 rounded-full h-2"><div class="bg-primary rounded-full h-2 transition-all" style="width:${Math.max(4,(e.count/maxCount)*100)}%"></div></div>
      <span class="mono text-[12px] text-ink-muted w-6 text-right shrink-0">${e.count}</span>
    </div>`).join(''):'<p class="text-[13px] text-ink-muted">Nenhuma empresa cadastrada.</p>';

  const bdayMesHTML=`<div class="flex items-end gap-1.5 h-24">${bDayPerMonth.map((v,i)=>`
    <div class="flex-1 flex flex-col items-center gap-1">
      <div class="w-full rounded-t-md ${i===new Date().getMonth()?'bg-primary':'bg-primary/25'} transition-all" style="height:${Math.max(4,(v/maxBday)*80)}px"></div>
      <span class="text-[9px] text-ink-muted font-medium">${meses[i]}</span>
    </div>`).join('')}</div>`;

  const ofertasHTML=`
    <div class="flex items-center gap-4 mb-3">
      <div class="text-center"><div class="text-[24px] font-bold text-green-600">${enviadas}</div><div class="text-[11px] text-ink-muted">Enviadas</div></div>
      <div class="flex-1 bg-surface-3 rounded-full h-3"><div class="bg-green-500 rounded-full h-3" style="width:${pct}%"></div></div>
      <div class="text-center"><div class="text-[24px] font-bold text-yellow-600">${pendentes}</div><div class="text-[11px] text-ink-muted">Pendentes</div></div>
    </div>
    <p class="text-[12px] text-ink-muted">${pct}% das ofertas foram enviadas.</p>`;

  const hhHTML=hhEmps.length?`
    <p class="text-[12.5px] text-ink-muted mb-3">${hhEmps.length} de ${totalEmp} empresas têm happy hour.</p>
    <div class="space-y-2">${hhEmps.slice(0,5).map(e=>`<div class="flex items-center gap-2 text-[13px]"><span class="text-yellow-600">🍺</span><span class="font-medium">${e.nome}</span></div>`).join('')}${hhEmps.length>5?`<p class="text-[12px] text-ink-muted">+${hhEmps.length-5} mais...</p>`:''}</div>`
    :'<p class="text-[13px] text-ink-muted">Nenhuma empresa com Happy Hour.</p>';

  const setEl=(id,html)=>{const el=document.getElementById(id);if(el)el.innerHTML=html;};
  setEl('rel-top-emp',topEmpHTML);
  setEl('rel-bday-mes',bdayMesHTML);
  setEl('rel-ofertas',ofertasHTML);
  setEl('rel-hh',hhHTML);
}

