    document.getElementById('e-oferta-val').value = emp.oferta_val || 'No dia do aniversário';
    document.getElementById('e-oferta-desc').value = emp.oferta_desc || '';
    document.getElementById('e-oferta-detalhe').value = emp.oferta_detalhe || '';
