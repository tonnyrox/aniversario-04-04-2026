    document.getElementById('e-uf').value = '';
    document.getElementById('e-oferta-tipo').value = 'Produto/Brinde Grátis';
    document.getElementById('e-oferta-val').value = 'No dia do aniversário';
    buildSched(null, 'e-');
    renderDonoPanel('', db);
  }
  
  updateOfertaPreview();
  
