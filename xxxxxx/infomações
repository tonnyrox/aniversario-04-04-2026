        document.getElementById('sug-autor-nome').textContent = autor.nome || '';
        document.getElementById('sug-autor-contato').textContent = [autor.tel, autor.email].filter(Boolean).join(' · ') || 'Sem contato';
        document.getElementById('sug-autor-master-id').textContent = autor.id;
      }
    }
    
    document.getElementById('sug-modal-title').textContent = sug.is_dono ? 'Avaliar Permissão de Negócio' : 'Analisar Indicação';
    document.getElementById('sug-modal-origem').textContent = sug.is_dono ? '👑 Solicitação de dono' : '💡 Indicação de comunidade';
    document.getElementById('sug-modal-origem')?.classList.remove('hidden');
    
    toggleSugStatus();
  }
  
  _sgCurrentStep = 1;
  document.querySelectorAll('#modal-sug .n-step').forEach(s => s.classList.remove('active'));
  document.getElementById('sg-step-1')?.classList.add('active');
  document.getElementById('sg-prev-btn')?.classList.add('hidden');
  document.getElementById('sg-next-btn').textContent = 'Próximo →';
  document.getElementById('sg-step-label').textContent = 'Etapa 1 de 4';
  
  for (let i = 1; i <= 4; i++) {
    const dot = document.getElementById('sg-dot-' + i);
    if (dot) dot.style.background = i === 1 ? '#3b5bdb' : '#e2e8f0';
  }
  
  openModal('modal-sug');
}

function toggleSugStatus() {
  const s = document.getElementById('sug-status')?.value;
  const isDono = document.getElementById('sug-is-dono')?.checked;
  const wrap = document.getElementById('sug-aprovado-action');
  
  if (!wrap) return;
  
  wrap.classList.toggle('hidden', s !== 'aprovado');
  
  if (s === 'aprovado') {
    wrap.className = isDono 
      ? 'rounded-xl p-4 border bg-purple-50 border-purple-200'
      : 'rounded-xl p-4 border bg-teal-50 border-teal-200';
    document.getElementById('sug-aprovado-msg').textContent = isDono 
      ? '🛡️ Ao aprovar, a empresa será ativada e vinculada ao ID Master do solicitante.'
      : '🤝 Ao aprovar, a empresa será adicionada como perfil da Comunidade.';
    document.getElementById('sug-criar-empresa-label').textContent = isDono 
      ? 'Sim, ativar perfil e vincular ao dono'
      : 'Sim, adicionar à comunidade';
  }
}

function sgStep(n) {
  if (n === 1 && _sgCurrentStep === 4) {
    salvarSugestao();
    return;
  }
  
  if (n === 1 && _sgCurrentStep === 1) {
    const nome = document.getElementById('sug-nome')?.value.trim();
    if (!nome) {
      toast('O nome da empresa é obrigatório.', 'err');
      return;
    }
  }
  
  document.getElementById('sg-step-' + _sgCurrentStep)?.classList.remove('active');
  _sgCurrentStep += n;
  document.getElementById('sg-step-' + _sgCurrentStep)?.classList.add('active');
  
  document.getElementById('sg-prev-btn')?.classList.toggle('hidden', _sgCurrentStep === 1);
  document.getElementById('sg-next-btn').textContent = _sgCurrentStep === 4 ? 'Salvar ✓' : 'Próximo →';
  document.getElementById('sg-step-label').textContent = 'Etapa ' + _sgCurrentStep + ' de 4';
  
  for (let i = 1; i <= 4; i++) {
    const dot = document.getElementById('sg-dot-' + i);
    if (dot) dot.style.background = i <= _sgCurrentStep ? '#3b5bdb' : '#e2e8f0';
  }
  
  const box = document.getElementById('modal-sug')?.querySelector('.modal-form-box');
  if (box) box.scrollTop = 0;
}

function salvarSugestao() {
  const nome = document.getElementById('sug-nome')?.value.trim();
  const oferta_desc = document.getElementById('sug-oferta-desc')?.value.trim();
  
  if (!nome) {
    toast('O nome do local é obrigatório.', 'err');
    return;
  }
  if (!oferta_desc) {
    toast('Descreva a oferta de aniversário.', 'err');
    return;
  }
  
  const is_dono = document.getElementById('sug-is-dono')?.checked;
  const db = load();
  if (!db.sugestoes) db.sugestoes = [];
  
  const editId = document.getElementById('sug-id')?.value;
  const sugOriginal = editId ? (db.sugestoes.find(s => s.id === editId) || {}) : {};
  
  const getVal = (id, fallback = '') => (document.getElementById(id)?.value.trim() || fallback);
  
  const sug = {
    id: editId || gid('ind'),
    autor_id: sugOriginal.autor_id || '',
    nome,
    segmento: getVal('sug-segmento'),
    tel: getVal('sug-tel'),
    email: getVal('sug-email'),
    ig: getVal('sug-ig'),
    site: getVal('sug-site'),
    cardapio: getVal('sug-cardapio'),
    rua: getVal('sug-rua'),
    num: getVal('sug-num'),
    comp: sugOriginal.comp || '',
    bairro: getVal('sug-bairro'),
    cep: getVal('sug-cep'),
    cidade: getVal('sug-cidade'),
    uf: getVal('sug-uf') || sugOriginal.uf || '',
    horarios: sugOriginal.horarios || null,
    hh_desc: sugOriginal.hh_desc || '',
    oferta_tipo: getVal('sug-oferta-tipo', 'Produto/Brinde Grátis') || sugOriginal.oferta_tipo || '',
    oferta_val: getVal('sug-oferta-val', 'No dia do aniversário') || sugOriginal.oferta_val || '',
    oferta_desc,
    oferta_regras: getVal('sug-oferta-regras'),
    obs: getVal('sug-obs'),
    status: document.getElementById('sug-status')?.value || 'pendente',
    is_dono,
    criado_em: sugOriginal.criado_em || new Date().toISOString(),
    atualizado_em: new Date().toISOString(),
  };
  
  if (editId) {
    const i = db.sugestoes.findIndex(s => s.id === editId);
    if (i !== -1) db.sugestoes[i] = sug;
  } else {
    db.sugestoes.unshift(sug);
  }
  
  if (sug.status === 'aprovado' && document.getElementById('sug-criar-empresa')?.checked) {
    const jaExiste = db.empresas.some(e => e.origem_sug_id === sug.id);
    if (!jaExiste) {
      db.empresas.unshift({
        id: gid('neg'),
        origem_sug_id: sug.id,
        nome: sug.nome,
        dono_id: sug.is_dono ? sug.autor_id : '',
        status_perfil: sug.is_dono ? 'verificado' : 'comunidade',
        segmento: sug.segmento || '',
        tel: sug.tel || '',
        email: sug.email || '',
        ig: sug.ig || '',
        site: sug.site || '',
        cardapio: sug.cardapio || '',
        rua: sug.rua || '',
        num: sug.num || '',
        comp: sug.comp || '',
        bairro: sug.bairro || '',
        cep: sug.cep || '',
        cidade: sug.cidade || '',
        uf: sug.uf || '',
        horarios: sug.horarios || null,
        hh_desc: sug.hh_desc || '',
        oferta_tipo: sug.oferta_tipo || 'Produto/Brinde Grátis',
        oferta_val: sug.oferta_val || 'No dia do aniversário',
        oferta_desc: sug.oferta_desc || '',
        oferta_regras: sug.oferta_regras || '',
        criado_em: sug.criado_em || new Date().toISOString(),
        aprovado_em: new Date().toISOString(),
        origem: sug.is_dono ? 'solicitacao_dono' : 'indicacao_comunidade'
      });
    }
  }
  
  save(db);
  closeModal('modal-sug');
  
  if (document.getElementById('sug-is-dono')?.checked) {
    renderSolicitacoes();
  } else {
    renderSugestoes();
  }
  
  updateSugestoesBadge();
  toast(editId ? 'Sugestão atualizada!' : 'Sugestão registrada!');
}

function excluirSugestao(id) {
  const db = load();
  const sug = (db.sugestoes || []).find(s => s.id === id);
  const wasDono = sug && sug.is_dono;
  
  db.sugestoes = (db.sugestoes || []).filter(s => s.id !== id);
  save(db);
  
  if (wasDono) {
    renderSolicitacoes();
  } else {
    renderSugestoes();
  }
  
  updateSugestoesBadge();
  toast('Removido.');
}

function aprovarSolicitacao(id) {
  const db = load();
  const sug = (db.sugestoes || []).find(s => s.id === id);
  if (!sug) return;
  
  sug.status = 'aprovado';
  
  const jaExiste = db.empresas.some(e => e.origem_sug_id === id);
  if (!jaExiste) {
    db.empresas.unshift({
      id: gid('neg'),
      origem_sug_id: id,
      nome: sug.nome,
      dono_id: sug.autor_id,
      status_perfil: 'verificado',
      segmento: sug.segmento || '',
      tel: sug.tel || '',
      email: sug.email || '',
      ig: sug.ig || '',
      site: sug.site || '',
      cardapio: sug.cardapio || '',
      rua: sug.rua || '',
      num: sug.num || '',
      comp: sug.comp || '',
      bairro: sug.bairro || '',
      cep: sug.cep || '',
      cidade: sug.cidade || '',
      uf: sug.uf || '',
      horarios: sug.horarios || null,
      hh_desc: sug.hh_desc || '',
      oferta_tipo: sug.oferta_tipo || 'Produto/Brinde Grátis',
      oferta_val: sug.oferta_val || 'No dia do aniversário',
      oferta_desc: sug.oferta_desc || '',
      oferta_regras: sug.oferta_regras || '',
      criado_em: sug.criado_em || new Date().toISOString(),
      aprovado_em: new Date().toISOString(),
      origem: 'solicitacao_dono'
    });
  }
  
  save(db);
  renderSolicitacoes();
  updateSugestoesBadge();
  toast('Solicitação aprovada! Empresa vinculada ao dono.');
}

function recusarSolicitacao(id) {
  const db = load();
  const i = (db.sugestoes || []).findIndex(s => s.id === id);
  if (i !== -1) {
    db.sugestoes[i].status = 'recusado';
    save(db);
    renderSolicitacoes();
    updateSugestoesBadge();
    toast('Solicitação recusada.');
  }
}

