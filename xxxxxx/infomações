  if(!nome){toast('Nome do cliente é obrigatório.','err');return;}
  if(!nasc){toast('Data de nascimento é obrigatória.','err');return;}
  const db=load(),editId=document.getElementById('c-id').value;
  const prev=editId?db.clientes.find(c=>c.id===editId)||{}:{};
  const cli={
    id:editId||gid(),
    nome,
    email:document.getElementById('c-email').value.trim(),
    tel:document.getElementById('c-tel').value.trim(),
    nasc,
    emp_id:document.getElementById('c-emp').value,
    rua:document.getElementById('c-rua').value.trim(),
