<script>
// @ts-nocheck
// ── DATA ──────────────────────────────────────────────
const KEY='anivcrm_v2';
function gid(){return Date.now().toString(36)+Math.random().toString(36).slice(2,6);}
function load(){
  try{
    const db=JSON.parse(localStorage.getItem(KEY))||{empresas:[],clientes:[]};
    let migrated=false;
    (db.clientes||[]).forEach(c=>{if(!c.perfil_id){c.perfil_id=gid();migrated=true;}});
    if(migrated)localStorage.setItem(KEY,JSON.stringify(db));
    return db;
  }catch{return{empresas:[],clientes:[]};}
}
function save(d){localStorage.setItem(KEY,JSON.stringify(d));}

// ── INIT ──────────────────────────────────────────────
document.addEventListener('DOMContentLoaded',()=>{
  updateDate();
  renderDashboard();
  checkBdayAlert();
  updateSugestoesBadge();
  document.getElementById('sug-status').addEventListener('change',toggleSugStatus);
});

function updateDate(){
  const d=new Date();
  document.getElementById('topbar-date').textContent=d.toLocaleDateString('pt-BR',{weekday:'long',year:'numeric',month:'long',day:'numeric'});
  const h=d.getHours();
  document.getElementById('dash-greet').textContent=(h<12?'Bom dia':h<18?'Boa tarde':'Boa noite')+'! 👋';
  document.getElementById('dash-sub').textContent='Resumo do CRM em '+d.toLocaleDateString('pt-BR',{day:'2-digit',month:'long'})+'.';
}

// ── NAV ───────────────────────────────────────────────
const SCREEN_NAMES={dashboard:'Dashboard',empresas:'Empresas',clientes:'Clientes',aniversarios:'Aniversários',sugestoes:'Indicações',meuperfil:'Meu Perfil'};
let empTab='ativas';
let solFiltro='pendente';
function gotoScreen(name,btn){
  document.querySelectorAll('.screen').forEach(s=>s.classList.add('hidden'));
  document.querySelectorAll('.nav-btn').forEach(n=>n.classList.remove('active'));
  document.getElementById('screen-'+name).classList.remove('hidden');
  if(btn)btn.classList.add('active');
  else document.querySelectorAll('.nav-btn').forEach(b=>{if((b.getAttribute('onclick')||'').includes("'"+name+"'"))b.classList.add('active');});
  const SCREEN_NAMES_LOCAL={'dashboard':'Dashboard','empresas':'Empresas','clientes':'Clientes','aniversarios':'Aniversários','sugestoes':'Indicações','meuperfil':'Meu Perfil'};
  document.getElementById('topbar-title').textContent=SCREEN_NAMES_LOCAL[name]||name;
  if(name==='dashboard')renderDashboard();
  if(name==='empresas'){ if(empTab==='ativas') renderEmpresas(); else renderSolicitacoes(); }
  if(name==='clientes')renderClientes();
  if(name==='aniversarios')renderAniversarios();
  if(name==='sugestoes')renderSugestoes();
  if(name==='meuperfil')renderMeuPerfil();
}

// ── DASHBOARD ─────────────────────────────────────────
function renderDashboard(){
  const db=load(),today=mmdd(new Date());
  const bdayToday=db.clientes.filter(c=>bdayMMDD(c.nasc)===today);
  const bdayWeek=db.clientes.filter(c=>bdayThisWeek(c.nasc));
  const enviadas=db.clientes.filter(c=>c.oferta_enviada).length;
  const pendentes=db.clientes.length-enviadas;
  const hhEmps=db.empresas.filter(e=>e.horarios&&e.horarios.some(h=>h.hh)).length;
  const solPend=(db.sugestoes||[]).filter(s=>s.status==='pendente'&&s.is_dono).length;
  const bdayMes=db.clientes.filter(c=>{if(!c.nasc)return false;const m=String(new Date().getMonth()+1).padStart(2,'0');return c.nasc.split('-')[1]===m;}).length;

  const verif=db.empresas.filter(e=>e.status_perfil==='verificado').length;
  // Grid unificado — 8 cards clicáveis com barra de progresso
  const cards=[
    {icon:'🏢',label:'Empresas',val:db.empresas.length,
     sub:verif+' verificadas · '+(db.empresas.length-verif)+' comunidade',
     cls:'stat-b1',ic:'bg-blue-50 text-blue-600',bar:'bg-blue-400',
     pct:db.empresas.length?Math.round((verif/db.empresas.length)*100):0,
     screen:'empresas',color:'text-blue-600'},
    {icon:'👥',label:'Clientes',val:db.clientes.length,
     sub:bdayMes+' aniversariam este mês',
     cls:'stat-b2',ic:'bg-indigo-50 text-indigo-500',bar:'bg-indigo-400',
     pct:db.clientes.length?Math.round((bdayMes/db.clientes.length)*100):0,
     screen:'clientes',color:'text-indigo-500'},
    {icon:'🎂',label:'Aniversários Hoje',val:bdayToday.length,
     sub:bdayToday.length===0?'Nenhum hoje':'Parabéns a eles! 🎉',
     cls:'stat-b3',ic:'bg-green-50 text-green-600',bar:'bg-green-400',
     pct:bdayToday.length>0?100:0,
     screen:'aniversarios',color:'text-green-600'},
    {icon:'📅',label:'Esta Semana',val:bdayWeek.length,
     sub:'próximos 7 dias',
     cls:'stat-b4',ic:'bg-yellow-50 text-yellow-600',bar:'bg-yellow-400',
     pct:bdayWeek.length>0?Math.min(100,bdayWeek.length*14):0,
     screen:'aniversarios',color:'text-yellow-600'},
    {icon:'✓',label:'Ofertas Enviadas',val:enviadas,
     sub:db.clientes.length?(Math.round((enviadas/db.clientes.length)*100)+'% dos clientes'):'—',
     cls:'',ic:'bg-emerald-50 text-emerald-600',bar:'bg-emerald-400',
     pct:db.clientes.length?Math.round((enviadas/db.clientes.length)*100):0,
     screen:'aniversarios',color:'text-emerald-600'},
    {icon:'⏳',label:'Ofertas Pendentes',val:pendentes,
     sub:'ainda não enviadas',
     cls:'',ic:'bg-orange-50 text-orange-500',bar:'bg-orange-300',
     pct:db.clientes.length?Math.round((pendentes/db.clientes.length)*100):0,
     screen:'aniversarios',color:'text-orange-500'},
    {icon:'🍺',label:'Com Happy Hour',val:hhEmps,
     sub:'de '+db.empresas.length+' empresas',
     cls:'',ic:'bg-amber-50 text-amber-600',bar:'bg-amber-400',
     pct:db.empresas.length?Math.round((hhEmps/db.empresas.length)*100):0,
     screen:'empresas',color:'text-amber-600'},
    {icon:'👑',label:'Solicitações',val:solPend,
     sub:solPend===0?'Nenhuma pendente':'Aguardando aprovação',
     cls:'',ic:'bg-purple-50 text-purple-600',bar:solPend>0?'bg-purple-400':'bg-surface-3',
     pct:solPend>0?100:0,
     screen:'empresas',color:'text-purple-600'},
  ];
  document.getElementById('stats-grid').innerHTML=cards.map(s=>`
    <div onclick="gotoScreen('${s.screen}',null)" class="bg-white rounded-2xl border border-edge p-5 shadow-sm ${s.cls} cursor-pointer hover:shadow-md hover:border-primary/30 transition-all group relative overflow-hidden">
      <div class="flex items-start justify-between mb-3">
        <div class="w-9 h-9 rounded-xl ${s.ic} flex items-center justify-center text-[17px] shrink-0">${s.icon}</div>
        <span class="text-[10px] ${s.color} opacity-0 group-hover:opacity-100 transition-opacity font-semibold mt-1">→</span>
      </div>
      <div class="text-[26px] font-bold tracking-tight leading-none mb-0.5">${s.val}</div>
      <div class="text-[12px] font-semibold text-ink mb-0.5">${s.label}</div>
      <div class="text-[11px] text-ink-muted mb-3">${s.sub}</div>
      ${s.bar?`<div class="h-1 bg-surface-3 rounded-full overflow-hidden"><div class="${s.bar} h-1 rounded-full" style="width:${s.pct}%"></div></div>`:''}
    </div>`).join('');

  const bdayCard=c=>{
    const emp=db.empresas.find(e=>e.id===c.emp_id);
    const ini=c.nome.split(' ').map(w=>w[0]).slice(0,2).join('').toUpperCase();
    return `<div class="flex items-center gap-3 py-3 border-b border-edge last:border-0">
      <div class="w-9 h-9 rounded-full bg-primary-light border border-primary-border flex items-center justify-center text-[12px] font-bold text-primary shrink-0">${ini}</div>
      <div class="flex-1 min-w-0"><div class="font-semibold text-[13.5px] truncate">${c.nome}</div><div class="text-[12px] text-ink-muted truncate">${emp?'🏢 '+emp.nome:'—'} · ${c.tel||c.email||'Sem contato'}</div></div>
      ${c.oferta_enviada?'<span class="text-[11px] text-green-600 font-bold mono">✓ Enviado</span>':`<button onclick="marcarEnviado('${c.id}')" class="text-[12px] text-ink-muted hover:text-ink px-2 py-1 rounded hover:bg-surface-3 transition-colors shrink-0">Marcar</button>`}
    </div>`;
  };
  const tc=document.getElementById('dash-today');
  tc.innerHTML=bdayToday.length?bdayToday.map(bdayCard).join(''):'<div class="text-center py-8 text-ink-muted"><div class="text-3xl mb-2 opacity-40">😴</div><p class="text-[13px]">Nenhum aniversariante hoje.</p></div>';
  const wc=document.getElementById('dash-week');
  const wo=bdayWeek.filter(c=>bdayMMDD(c.nasc)!==today);
  wc.innerHTML=wo.length?wo.slice(0,6).map(bdayCard).join(''):'<div class="text-center py-8 text-ink-muted"><div class="text-3xl mb-2 opacity-40">🗓️</div><p class="text-[13px]">Nenhum nos próximos dias.</p></div>';

  // Relatórios (chamados de dentro do dashboard)
  renderRelatorios();
}

// ── SCHEDULE / HH ──────────────────────────────────────
const DIAS=['Segunda-feira','Terça-feira','Quarta-feira','Quinta-feira','Sexta-feira','Sábado','Domingo'];

function buildSched(horarios){
  const c=document.getElementById('sched-container'); c.innerHTML='';
  const data=horarios&&horarios.length===7?horarios:DIAS.map((d,i)=>({dia:d,slots:[{ini:'08:00',fim:'18:00'}],fechado:false,hh:false,hh_slots:[{ini:'17:00',fim:'19:00'}]}));
  data.forEach((h,i)=>c.appendChild(buildDiaRow(h,i)));
  updateHHDescVis();
}

function buildDiaRow(h,i){
  const div=document.createElement('div');
  div.className='sched-row'+(h.fechado?' closed':'');
  div.dataset.idx=i;
  const hhSlots=h.hh_slots&&h.hh_slots.length?h.hh_slots:[{ini:'17:00',fim:'19:00'}];
  div.innerHTML=`
    <div class="flex items-center gap-3 px-4 py-2.5">
      <span class="w-28 text-[12.5px] font-bold text-ink shrink-0">${h.dia}</span>
      <div class="flex items-center gap-2 flex-wrap flex-1" id="slots-${i}">
        ${h.slots.map((s,si)=>slotHTML(i,si,s.ini,s.fim)).join('')}
        ${!h.fechado?`<button onclick="addSlot(${i})" type="button" class="text-[11px] border border-dashed border-edge-strong text-ink-muted rounded px-2 py-0.5 hover:border-primary hover:text-primary hover:bg-primary-light transition-all">+ intervalo</button>`:''}
      </div>
      <label class="flex items-center gap-1.5 text-[11.5px] text-ink-muted cursor-pointer shrink-0"><input type="checkbox" ${h.fechado?'checked':''} onchange="toggleFechado(${i},this)" class="accent-primary"> Fechado</label>
    </div>
    <div class="hh-sub flex items-center gap-3 px-4 py-2" id="hh-row-${i}" ${h.fechado?'style="opacity:.4;pointer-events:none"':''}>
      <span class="w-28 text-[11px] font-bold text-primary shrink-0">🍺 Happy Hour</span>
      <div class="flex items-center gap-2 flex-wrap flex-1" id="hh-slots-${i}">
        ${h.hh?hhSlots.map((s,si)=>hhSlotHTML(i,si,s.ini,s.fim)).join('')+`<button onclick="addHHSlot(${i})" type="button" class="text-[11px] border border-dashed border-primary-border text-primary rounded px-2 py-0.5 hover:bg-primary-light transition-all">+ intervalo</button>`:'<span class="text-[11.5px] text-ink-light italic">Sem HH neste dia</span>'}
      </div>
      <label class="flex items-center gap-1.5 text-[11.5px] text-ink-muted cursor-pointer shrink-0"><input type="checkbox" ${h.hh?'checked':''} onchange="toggleHHDia(${i},this)" class="accent-primary"> Tem HH</label>
    </div>`;
  return div;
}

function slotHTML(di,si,ini,fim){return `<span id="slot-${di}-${si}" class="flex items-center gap-1.5"><input type="time" id="si-${di}-${si}" value="${ini}" class="border border-edge rounded px-2 focus:outline-none focus:border-primary" style="width:88px;height:30px"><span class="text-[11px] text-ink-light font-semibold">às</span><input type="time" id="sf-${di}-${si}" value="${fim}" class="border border-edge rounded px-2 focus:outline-none focus:border-primary" style="width:88px;height:30px">${si>0?`<button onclick="removeSlot(${di},${si})" type="button" class="text-ink-light hover:text-red-500 text-[15px] px-1 transition-colors">×</button>`:''}</span>`;}

function hhSlotHTML(di,si,ini,fim){return `<span id="hh-slot-${di}-${si}" class="flex items-center gap-1.5"><input type="time" id="hsi-${di}-${si}" value="${ini}" class="border border-primary-border rounded px-2 bg-white focus:outline-none focus:border-primary" style="width:88px;height:28px"><span class="text-[11px] text-ink-light font-semibold">às</span><input type="time" id="hsf-${di}-${si}" value="${fim}" class="border border-primary-border rounded px-2 bg-white focus:outline-none focus:border-primary" style="width:88px;height:28px">${si>0?`<button onclick="removeHHSlot(${di},${si})" type="button" class="text-ink-light hover:text-red-500 text-[15px] px-1 transition-colors">×</button>`:''}</span>`;}

function addSlot(di){const s=document.getElementById('slots-'+di),btn=s.querySelector('button'),n=s.querySelectorAll('[id^="slot-'+di+'-"]').length,tmp=document.createElement('div');tmp.innerHTML=slotHTML(di,n,'13:00','18:00');s.insertBefore(tmp.firstChild,btn);}
function removeSlot(di,si){const e=document.getElementById('slot-'+di+'-'+si);if(e)e.remove();}
function addHHSlot(di){const s=document.getElementById('hh-slots-'+di),btn=s.querySelector('button'),n=s.querySelectorAll('[id^="hh-slot-'+di+'-"]').length,tmp=document.createElement('div');tmp.innerHTML=hhSlotHTML(di,n,'17:00','19:00');s.insertBefore(tmp.firstChild,btn);}
function removeHHSlot(di,si){const e=document.getElementById('hh-slot-'+di+'-'+si);if(e)e.remove();}

function toggleFechado(i,cb){
  const row=document.querySelector('.sched-row[data-idx="'+i+'"]');
  row.classList.toggle('closed',cb.checked);
  row.querySelectorAll('input[type=time]').forEach(x=>x.disabled=cb.checked);
  const ab=document.getElementById('slots-'+i).querySelector('button[onclick^="addSlot"]');if(ab)ab.style.display=cb.checked?'none':'';
  const hhr=document.getElementById('hh-row-'+i);
  if(hhr){
    if(cb.checked){hhr.style.opacity='.4';hhr.style.pointerEvents='none';}
    else{hhr.style.opacity='';hhr.style.pointerEvents='';}
  }
}
function toggleHHDia(i,cb){
  const s=document.getElementById('hh-slots-'+i);
  s.innerHTML=cb.checked?hhSlotHTML(i,0,'17:00','19:00')+`<button onclick="addHHSlot(${i})" type="button" class="text-[11px] border border-dashed border-primary-border text-primary rounded px-2 py-0.5 hover:bg-primary-light transition-all">+ intervalo</button>`:'<span class="text-[11.5px] text-ink-light italic">Sem HH neste dia</span>';
  updateHHDescVis();
}
function updateHHDescVis(){
  const any=!!document.querySelector('#sched-container .hh-sub input[type=checkbox]:checked');
  document.getElementById('hh-desc-wrap').classList.toggle('hidden',!any);
}
function collectSched(){
  return Array.from(document.querySelectorAll('.sched-row')).map((row,i)=>{
    const fechado=row.querySelector('.flex:first-child label input')?.checked||false;
    const hh=document.getElementById('hh-row-'+i)?.querySelector('label input')?.checked||false;
    const slots=Array.from(document.getElementById('slots-'+i)?.querySelectorAll('[id^="slot-'+i+'-"]')||[]).map((_,si)=>({ini:(document.getElementById('si-'+i+'-'+si)||{}).value||'',fim:(document.getElementById('sf-'+i+'-'+si)||{}).value||''}));
    const hh_slots=Array.from(document.getElementById('hh-slots-'+i)?.querySelectorAll('[id^="hh-slot-'+i+'-"]')||[]).map((_,si)=>({ini:(document.getElementById('hsi-'+i+'-'+si)||{}).value||'',fim:(document.getElementById('hsf-'+i+'-'+si)||{}).value||''}));
    return{dia:DIAS[i],slots,fechado,hh,hh_slots};
  });
}

// ── EMPRESAS ──────────────────────────────────────────
