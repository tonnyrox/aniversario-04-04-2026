}

function verificarBanco() {
  const db = load();
  const empresas = db.empresas || [];
  const clientes = db.clientes || [];
  const empIds = new Set(empresas.map(e => e.id));
  const cliIds = new Set(clientes.map(c => c.id));
  const problemas = [];

  // 1. Empresas sem nome
  empresas.forEach(e => {
    if (!e.nome || !e.nome.trim())
      problemas.push({ tipo:'erro', msg:'Empresa ID <code>'+e.id+'</code> está sem nome.' });
  });

  // 2. Empresas com dono_id inválido
  empresas.forEach(e => {
    if (e.dono_id && !cliIds.has(e.dono_id))
      problemas.push({ tipo:'erro', msg:'Empresa <strong>'+e.nome+'</strong> tem dono_id <code>'+e.dono_id+'</code> que não existe nos clientes.' });
  });

  // 3. Verificado sem dono
  empresas.forEach(e => {
    if (e.status_perfil === 'verificado' && !e.dono_id)
      problemas.push({ tipo:'aviso', msg:'Empresa <strong>'+e.nome+'</strong> está como Verificado mas sem dono vinculado.' });
  });

  // 4. Empresa sem oferta
  empresas.forEach(e => {
    if (!e.oferta_desc || !e.oferta_desc.trim())
      problemas.push({ tipo:'aviso', msg:'Empresa <strong>'+(e.nome||e.id)+'</strong> não tem oferta de aniversário cadastrada.' });
  });

  // 5. Cliente com emp_id inválido
  clientes.forEach(c => {
    if (c.emp_id && !empIds.has(c.emp_id))
      problemas.push({ tipo:'erro', msg:'Cliente <strong>'+(c.nome||c.id)+'</strong> tem emp_id <code>'+c.emp_id+'</code> que não existe nas empresas.' });
  });

  // 6. Cliente sem nome
  clientes.forEach(c => {
    if (!c.nome || !c.nome.trim())
      problemas.push({ tipo:'erro', msg:'Cliente ID <code>'+c.id+'</code> está sem nome.' });
  });

  // 7. Cliente sem nascimento
  clientes.forEach(c => {
    if (!c.nasc)
      problemas.push({ tipo:'aviso', msg:'Cliente <strong>'+(c.nome||c.id)+'</strong> não tem data de nascimento.' });
  });

  // 8. IDs duplicados
  const empIdList = empresas.map(e => e.id);
  const dupEmp = empIdList.filter((id,i) => empIdList.indexOf(id) !== i);
  if (dupEmp.length) problemas.push({ tipo:'erro', msg:'IDs duplicados em empresas: '+[...new Set(dupEmp)].join(', ') });

  const cliIdList = clientes.map(c => c.id);
  const dupCli = cliIdList.filter((id,i) => cliIdList.indexOf(id) !== i);
  if (dupCli.length) problemas.push({ tipo:'erro', msg:'IDs duplicados em clientes: '+[...new Set(dupCli)].join(', ') });

  const erros  = problemas.filter(p => p.tipo === 'erro');
  const avisos = problemas.filter(p => p.tipo === 'aviso');
  const el = document.getElementById('adm-checker-result');

  if (!problemas.length) {
    el.innerHTML = '<div class="flex items-center gap-3 bg-green-50 border border-green-200 rounded-xl px-4 py-3">'
      + '<span class="text-2xl">\u2705</span>'
      + '<div><p class="font-bold text-green-700 text-[13.5px]">Banco de dados \u00edntegro!</p>'
      + '<p class="text-[12.5px] text-green-600 mt-0.5">'+empresas.length+' empresas e '+clientes.length+' clientes verificados sem nenhum problema.</p></div></div>';
    return;
  }

  let html = '<div class="space-y-2">'
    + '<div class="flex gap-3 text-[13px] font-semibold mb-3">'
    + '<span class="text-red-600">'+erros.length+' erro'+(erros.length!==1?'s':'')+'</span>'
    + '<span class="text-ink-muted">\u00b7</span>'
    + '<span class="text-yellow-600">'+avisos.length+' aviso'+(avisos.length!==1?'s':'')+'</span>'
    + '</div>';

  erros.forEach(p => {
    html += '<div class="flex items-start gap-2.5 bg-red-50 border border-red-200 rounded-lg px-3.5 py-2.5">'
      + '<span class="text-red-500 mt-0.5 shrink-0">\u2716</span>'
      + '<p class="text-[12.5px] text-red-700">'+p.msg+'</p></div>';
  });

  avisos.forEach(p => {
    html += '<div class="flex items-start gap-2.5 bg-yellow-50 border border-yellow-200 rounded-lg px-3.5 py-2.5">'
      + '<span class="text-yellow-500 mt-0.5 shrink-0">\u26a0</span>'
      + '<p class="text-[12.5px] text-yellow-700">'+p.msg+'</p></div>';
  });

  html += '</div>';
  el.innerHTML = html;
}

